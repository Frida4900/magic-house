{
  "name": "movie-rating-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w movie-rating-backend\" \"npm run dev -w movie-rating-frontend\"",
    "build": "npm run build -w movie-rating-frontend",
    "test": "npm run test -w movie-rating-backend",
    "sync:movies": "npm run sync:movies -w movie-rating-backend",
    "prisma:generate": "npm run prisma:generate -w movie-rating-backend",
    "prisma:migrate": "npm run prisma:migrate -w movie-rating-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

